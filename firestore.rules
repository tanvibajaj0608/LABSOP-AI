rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'tanvibajaj0608@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId
                    && incoming().role == 'scientist'
                    && incoming().keys().hasAll(['uid', 'email', 'role', 'createdAt', 'displayName', 'dailySopCount', 'lastSopReset'])
                    && incoming().keys().size() == 7;
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid == userId)
                    && (isAdmin() || (
                      incoming().role == existing().role &&
                      incoming().email == existing().email &&
                      incoming().uid == existing().uid &&
                      (incoming().dailySopCount == existing().dailySopCount || incoming().dailySopCount == (existing().dailySopCount + 1) || (incoming().dailySopCount == 1 && incoming().lastSopReset == request.time))
                    ));
    }

    // SOP Documents
    match /sops/{sopId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && isEmailVerified()
                    && isValidId(sopId)
                    && request.resource.data.createdBy == request.auth.uid
                    && request.resource.data.currentVersion == 1
                    && request.resource.data.createdAt == request.time
                    && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('dailySopCount', 0) < 5);
      allow update: if isSignedIn() && isEmailVerified() && (request.auth.token.email == 'tanvibajaj0608@gmail.com' || resource.data.createdBy == request.auth.uid)
                    && request.resource.data.updatedAt == request.time
                    && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isSignedIn() && isEmailVerified() && (request.auth.token.email == 'tanvibajaj0608@gmail.com' || resource.data.createdBy == request.auth.uid);
    }

    // Revisions
    match /sops/{sopId}/revisions/{revisionId} {
      allow read: if isSignedIn() && (isAdmin() || get(/databases/$(database)/documents/sops/$(sopId)).data.createdBy == request.auth.uid);
      allow create: if isSignedIn() && isEmailVerified()
                    && (isAdmin() || get(/databases/$(database)/documents/sops/$(sopId)).data.createdBy == request.auth.uid)
                    && incoming().sopId == sopId
                    && incoming().createdBy == request.auth.uid
                    && incoming().createdAt == request.time;
      allow delete: if isSignedIn() && isEmailVerified() && (isAdmin() || get(/databases/$(database)/documents/sops/$(sopId)).data.createdBy == request.auth.uid);
      allow update: if false;
    }

    // Support Messages
    match /support/{msgId} {
      allow create: if isSignedIn() 
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }

    // Feedback
    match /feedback/{feedbackId} {
      allow create: if isSignedIn() 
                    && incoming().userId == request.auth.uid
                    && incoming().createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }
  }
}
