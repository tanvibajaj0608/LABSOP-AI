{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role and professional details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["scientist", "admin"] },
        "organization": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "SOP": {
      "title": "Standard Operating Procedure",
      "description": "The main SOP document metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "currentVersion": { "type": "integer" },
        "guidelines": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "organization": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "active", "retired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "currentVersion", "createdBy"]
    },
    "Revision": {
      "title": "SOP Revision",
      "description": "A specific version of an SOP.",
      "type": "object",
      "properties": {
        "sopId": { "type": "string" },
        "version": { "type": "integer" },
        "content": { "type": "string" },
        "changelog": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sopId", "version", "content", "createdBy"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profile and role information."
    },
    "sops/{sopId}": {
      "schema": "SOP",
      "description": "Root SOP documents."
    },
    "sops/{sopId}/revisions/{revisionId}": {
      "schema": "Revision",
      "description": "History of changes for a specific SOP."
    }
  }
}
